{
  "project": {
    "title": "Karma Trace Rust SDK",
    "id": "ktrace_rust"
  },
  "git": {
    "url": "https://github.com/QM-Code/ktrace-rust",
    "auth": "git@github.com:QM-Code/ktrace-rust.git"
  },
  "cargo": {
    "manifest": "src/Cargo.toml",
    "package": "ktrace",
    "tests": true,
    "demos": {
      "bootstrap": {
        "bin": "bootstrap"
      },
      "sdk/alpha": {
        "bin": "sdk_alpha"
      },
      "sdk/beta": {
        "bin": "sdk_beta"
      },
      "sdk/gamma": {
        "bin": "sdk_gamma"
      },
      "exe/core": {
        "bin": "core"
      },
      "exe/omega": {
        "bin": "omega"
      }
    }
  },
  "build": {
    "jobs": 4,
    "demos": [
      "bootstrap",
      "sdk/alpha",
      "sdk/beta",
      "sdk/gamma",
      "exe/core",
      "exe/omega"
    ],
    "defaults": {
      "demos": [
        "bootstrap",
        "sdk/alpha",
        "sdk/beta",
        "sdk/gamma",
        "exe/core",
        "exe/omega"
      ]
    }
  }
}
